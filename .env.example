# Django
DJANGO_SECRET_KEY=development-only-change-me-before-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=

# Production security (enable explicitly for a reviewed deployment)
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_TRUST_X_FORWARDED_PROTO=False
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False

# Logging
DJANGO_LOG_LEVEL=INFO

# ThreatLens
THREATLENS_DEMO_MODE=True
THREATLENS_MAX_UPLOAD_BYTES=5242880
THREATLENS_MAX_INPUT_CHARACTERS=30000
THREATLENS_MAX_PARSED_CHARACTERS=200000
THREATLENS_ANALYSIS_TIMEOUT_SECONDS=90

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_MAX_RETRIES=2
